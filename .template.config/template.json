{
  "$schema": "http://json.schemastore.org/template",
  "author": "JerryLuo",
  "classifications": [
    "Web",
    "API",
    "Clean Architecture"
  ],
  "identity": "Jex.CleanArchitecture.Template",
  "name": "Jex Clean Architecture",
  "shortName": "jex",
  "description": "A lightweight, opinionated Clean Architecture template for .NET 10 with CQRS, FreeSQL, JWT authentication, and built-in tests.",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "sourceName": "Jex",
  "preferNameDirectory": true,
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "The target framework for the project.",
      "datatype": "choice",
      "choices": [
        {
          "choice": "net10.0",
          "description": ".NET 10"
        }
      ],
      "defaultValue": "net10.0",
      "replaces": "net10.0"
    }
  }
}
